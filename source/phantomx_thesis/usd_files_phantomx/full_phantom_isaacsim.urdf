  <!-- ═══════════════════════════════════════════════════════════
       BASE LINK
  ═══════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════
       BODY
  ═══════════════════════════════════════════════════════════ -->
  <joint name="j_phantomx_attachment" type="fixed">
    <parent link="base_link"/>
    <child link="MP_BODY"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

